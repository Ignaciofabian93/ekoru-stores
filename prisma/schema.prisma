// ─── Enums ───────────────────────────────────────────────────────────────────────

enum Language {
  ES
  EN
  FR
  PT
  DE
}

enum ProductSize {
  XS
  S
  M
  L
  XL
}

enum WeightUnit {
  KG
  LB
  OZ
  G
}

enum Badge {
  POPULAR
  DISCOUNTED
  WOMAN_OWNED
  BEST_SELLER
  TOP_RATED
  COMMUNITY_FAVORITE
  LIMITED_TIME_OFFER
  FLASH_SALE
  BEST_VALUE
  HANDMADE
  SUSTAINABLE
  SUPPORTS_CAUSE
  FAMILY_BUSINESS
  CHARITY_SUPPORT
  LIMITED_STOCK
  SEASONAL
  FREE_SHIPPING
  FOR_REPAIR
  REFURBISHED
  EXCHANGEABLE
  LAST_PRICE
  FOR_GIFT
  OPEN_TO_OFFERS
  OPEN_BOX
  CRUELTY_FREE
  DELIVERED_TO_HOME
  IN_HOUSE_PICKUP
  IN_MID_POINT_PICKUP
}

enum DimensionUnit {
  CM
  M
  MM
  INCH
  FOOT
}

// ─── Models ──────────────────────────────────────────────────────────────────────

model StoreCategory {
  id            Int       @id @default(autoincrement())
  isActive      Boolean   @default(true)
  sortOrder     Int       @default(0)
  featuredFrom  DateTime?
  featuredUntil DateTime?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  storeSubCategory StoreSubCategory[]
  translations     StoreCategoryTranslation[]

  @@index([id])
  @@index([isActive, sortOrder])
  @@index([featuredUntil])
}

model StoreCategoryTranslation {
  id              Int      @id @default(autoincrement())
  storeCategoryId Int
  language        Language
  name            String
  slug            String
  href            String?

  metaTitle       String?
  metaDescription String?  @db.Text
  metaKeywords    String[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  storeCategory StoreCategory @relation(fields: [storeCategoryId], references: [id], onDelete: Cascade)

  @@unique([storeCategoryId, language])
  @@unique([slug, language])
  @@index([slug, language])
  @@index([language, storeCategoryId])
}

model StoreSubCategory {
  id              Int       @id @default(autoincrement())
  storeCategoryId Int
  isActive        Boolean   @default(true)
  sortOrder       Int       @default(0)
  featuredFrom    DateTime?
  featuredUntil   DateTime?

  averageWeight Float?       @default(0.0)
  size          ProductSize? @default(M)
  weightUnit    WeightUnit?  @default(KG)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  storeCategory StoreCategory                 @relation(fields: [storeCategoryId], references: [id])
  storeProducts StoreProduct[]
  materials     StoreProductMaterial[]
  translations  StoreSubCategoryTranslation[]

  @@index([storeCategoryId])
  @@index([featuredUntil])
}

model StoreSubCategoryTranslation {
  id                 Int      @id @default(autoincrement())
  storeSubCategoryId Int
  language           Language
  name               String
  slug               String
  keywords           String[]
  href               String?

  metaTitle       String?
  metaDescription String? @db.Text

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  storeSubCategory StoreSubCategory @relation(fields: [storeSubCategoryId], references: [id], onDelete: Cascade)

  @@unique([storeSubCategoryId, language])
  @@unique([slug, language])
  @@index([slug, language])
  @@index([language, storeSubCategoryId])
  @@index([language])
}

model StoreProduct {
  id          Int      @id @default(autoincrement())
  name        String
  description String
  stock       Int      @default(0)
  barcode     String?  @unique
  sku         String?
  price       Int
  hasOffer    Boolean  @default(false)
  offerPrice  Int?
  sellerId    String
  images      String[]
  isActive    Boolean  @default(true)
  badges      Badge[]
  brand       String?
  color       String?

  // Metrics & Engagement
  averageRating Float @default(0)
  reviewsNumber Int   @default(0)
  likesCount    Int   @default(0)
  saleCount     Int   @default(0)
  viewCount     Int   @default(0)

  // Product Specifications
  materialComposition String?
  recycledContent     Float?
  weight              Float?
  weightUnit          WeightUnit?    @default(KG)
  length              Float?
  width               Float?
  height              Float?
  dimensionUnit       DimensionUnit? @default(CM)

  // Inventory Management
  lowStockThreshold Int?    @default(5)
  isLowStock        Boolean @default(false)

  // SEO & Search
  tags            String[]
  metaTitle       String?
  metaDescription String?

  // Additional Info
  warranty         String?
  warrantyDuration Int?
  features         String[]

  subCategoryId Int

  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  deletedAt     DateTime?
  featuredFrom  DateTime?
  featuredUntil DateTime?

  productComment      ProductComment[]
  likes               StoreProductLike[]
  productVariant      ProductVariant[]
  materialCompositions StoreProductMaterialComposition[]
  storeSubCategory    StoreSubCategory                  @relation(fields: [subCategoryId], references: [id])
  storeProductReview  StoreProductReview[]

  @@index([sellerId])
  @@index([subCategoryId])
  @@index([isActive])
  @@index([sellerId, isActive])
  @@index([subCategoryId, isActive])
  @@index([stock])
  @@index([isLowStock])
  @@index([hasOffer, isActive])
  @@index([createdAt(sort: Desc), isActive])
  @@index([deletedAt])
  @@index([saleCount(sort: Desc)])
  @@index([viewCount(sort: Desc)])
  @@index([averageRating(sort: Desc)])
  @@index([reviewsNumber(sort: Desc)])
  @@index([likesCount(sort: Desc)])
  @@index([tags])
  @@index([featuredUntil])
}

model StoreProductMaterial {
  id                 Int     @id @default(autoincrement())
  storeSubCategoryId Int
  materialTypeId     Int
  quantity           Float
  unit               String  @default("percentage")
  isPrimary          Boolean @default(false)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  material         MaterialImpactEstimate @relation(fields: [materialTypeId], references: [id])
  storeSubCategory StoreSubCategory       @relation(fields: [storeSubCategoryId], references: [id], onDelete: Cascade)

  @@unique([storeSubCategoryId, materialTypeId])
  @@index([storeSubCategoryId])
  @@index([materialTypeId])
  @@index([isPrimary])
}

model StoreProductMaterialComposition {
  id             Int      @id @default(autoincrement())
  storeProductId Int
  materialTypeId Int
  percentage     Float
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  storeProduct StoreProduct           @relation(fields: [storeProductId], references: [id], onDelete: Cascade)
  material     MaterialImpactEstimate @relation(fields: [materialTypeId], references: [id])

  @@unique([storeProductId, materialTypeId])
  @@index([storeProductId])
  @@index([materialTypeId])
}

model MaterialImpactEstimate {
  id                      Int      @id @default(autoincrement())
  materialType            String   @unique
  estimatedCo2SavingsKG   Float
  estimatedWaterSavingsLT Float
  createdAt               DateTime @default(now())
  updatedAt               DateTime @updatedAt

  storeProductMaterials     StoreProductMaterial[]
  storeProductCompositions  StoreProductMaterialComposition[]
  translations              MaterialImpactEstimateTranslation[]

  @@index([materialType])
}

model MaterialImpactEstimateTranslation {
  id                       Int      @id @default(autoincrement())
  materialImpactEstimateId Int
  language                 Language
  materialTypeTranslation  String

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  materialImpactEstimate MaterialImpactEstimate @relation(fields: [materialImpactEstimateId], references: [id], onDelete: Cascade)

  @@unique([materialImpactEstimateId, language])
  @@index([language])
}

model ProductVariant {
  id             Int         @id @default(autoincrement())
  storeProductId Int
  name           String
  price          Int
  stock          Int
  color          String?
  size           ProductSize

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  product StoreProduct @relation(fields: [storeProductId], references: [id])

  @@unique([storeProductId, color, size])
}

model StoreProductReview {
  id                 Int          @id @default(autoincrement())
  storeProductId     Int
  userId             String
  rating             Int
  comment            String?
  images             String[]
  createdAt          DateTime     @default(now())
  updatedAt          DateTime     @updatedAt
  isVerifiedPurchase Boolean      @default(false)
  helpfulCount       Int          @default(0)
  storeProduct       StoreProduct @relation(fields: [storeProductId], references: [id], onDelete: Cascade)

  @@unique([storeProductId, userId])
  @@index([createdAt])
  @@index([isVerifiedPurchase])
  @@index([rating])
  @@index([storeProductId])
}

model ProductComment {
  id             Int          @id @default(autoincrement())
  comment        String
  sellerId       String
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt
  rating         Int?
  storeProductId Int
  storeProduct   StoreProduct @relation(fields: [storeProductId], references: [id])
}

model StoreProductLike {
  id             Int          @id @default(autoincrement())
  sellerId       String
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt
  storeProductId Int
  storeProduct   StoreProduct @relation(fields: [storeProductId], references: [id])

  @@unique([storeProductId, sellerId])
  @@index([storeProductId])
  @@index([sellerId])
  @@index([createdAt(sort: Desc)])
}

